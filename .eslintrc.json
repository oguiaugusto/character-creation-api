{
    "env": {
        "commonjs": true,
        "es2021": true,
        "node": true
    },
    "extends": [
        "airbnb-base"
    ],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "no-console": "off",
        "curly": "off",
        "function-paren-newline": "off",
        "consistent-return": "off",
        "object-curly-newline": ["error", {
            "multiline": true,
            "consistent": true
        }],
        "no-unused-vars": ["error", {
            "argsIgnorePattern": "^_"
        }],
        "newline-per-chained-call": ["error", {
            "ignoreChainWithDepth": 6
        }],
        "strict": "off",
        "no-loop-func": "warn"
    }
}
