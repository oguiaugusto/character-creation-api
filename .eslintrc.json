{
    "env": {
        "es6": true,
        "node": true
    },
    "extends": [
        "airbnb-base",
        "plugin:@typescript-eslint/recommended"
    ],
    "globals": {
        "Atomics": "readonly",
        "SharedArrayBuffer": "readonly"
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2018,
        "sourceType": "module"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "rules": {
        "import/extensions": [
            "error",
            "ignorePackages",
            {
              "ts": "never"
            }
        ],
        "object-curly-newline": "off",
        "import/no-extraneous-dependencies": ["error", {"devDependencies": true}]
    },
    "settings": {
        "import/no-unresolved": "error",
        "import/resolver": {
          "typescript": {}
        },
        "object-curly-newline": "off"
    }
}